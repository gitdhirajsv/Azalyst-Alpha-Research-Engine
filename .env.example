# Copy these into Render → Environment tab (values set automatically by render.yaml)
# Only ADMIN_KEY is secret — Render auto-generates it

INITIAL_BALANCE=1000.0    # starting paper balance in USD
TOP_N=5                   # longs + shorts per side each week
N_SYMBOLS=50              # universe size (top N by Binance 24h volume)
ADMIN_KEY=                # auto-generated by Render — used for /run-now endpoint
DB_PATH=/tmp/azalyst_paper.db   # SQLite path (ephemeral, survives restarts not redeploys)
PYTHONUNBUFFERED=1
